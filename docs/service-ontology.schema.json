{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veris.kr/schemas/service-ontology-lite.manifest.json",
  "title": "service-ontology-lite manifest",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "handler"],
        "properties": {
          "path": {"type": "string", "pattern": "^/"},
          "auth": {"type": "string", "enum": ["public", "required", "admin", "cron", "unknown"]},
          "handler": {"type": "string", "minLength": 1},
          "methods": {"type": "array", "items": {"type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]}},
          "entities": {"type": "array", "items": {"type": "string"}},
          "external_services": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "storage": {"type": "string"},
          "fields": {"type": "array", "items": {"type": "string"}},
          "exposed_at": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "external_services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "type": {"type": "string"},
          "env": {"type": "array", "items": {"type": "string"}},
          "used_by": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "jobs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "handler"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "schedule": {"type": "string"},
          "handler": {"type": "string", "minLength": 1},
          "auth": {"type": "string", "enum": ["cron", "admin", "required"]}
        }
      }
    },
    "agent_os": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "projects": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "name": {"type": "string"}
            }
          }
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "role": {"type": "string"}
            }
          }
        },
        "surfaces": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "type", "project_context_id"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "type": {"type": "string", "minLength": 1},
              "project_context_id": {"type": "string", "minLength": 1}
            }
          }
        },
        "tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "project_context_id", "owner_agent"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "project_context_id": {"type": "string", "minLength": 1},
              "owner_agent": {"type": "string", "minLength": 1},
              "surface_id": {"type": "string"},
              "skills": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "skills": {"type": "array", "items": {"$ref": "#/$defs/agentOsItem"}},
        "hooks": {"type": "array", "items": {"$ref": "#/$defs/agentOsItem"}},
        "loops": {"type": "array", "items": {"$ref": "#/$defs/agentOsItem"}},
        "plugins": {"type": "array", "items": {"$ref": "#/$defs/agentOsItem"}},
        "memories": {"type": "array", "items": {"$ref": "#/$defs/agentOsItem"}},
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "project_context_id"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "type": {"type": "string"},
              "project_context_id": {"type": "string", "minLength": 1}
            }
          }
        },
        "relations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source", "relation", "target"],
            "properties": {
              "source": {"type": "string", "minLength": 1},
              "relation": {"type": "string", "minLength": 1},
              "target": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    }
  },
  "$defs": {
    "agentOsItem": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "project_context_id": {"type": "string"}
      }
    }
  }
}
